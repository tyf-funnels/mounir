<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>سويفت باي — خدمات الدفع الرقمي السريعة والآمنة</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />
<style>
/* ─── TOKENS ─────────────────────────────────────────────── */
:root {
  --ink:      #0a0f1e;
  --ink-2:    #1a2035;
  --silver:   #8a94b0;
  --ghost:    #f0f3fa;
  --white:    #ffffff;
  --blue-1:   #1245ea;
  --blue-2:   #3b6ef8;
  --teal:     #00d4c8;
  --gold:     #f5c842;
  --wa:       #25D366;
  --wa-dark:  #128C7E;
  --radius-s: 12px;
  --radius-m: 20px;
  --radius-l: 32px;
  --shadow-s: 0 4px 24px rgba(18,69,234,.12);
  --shadow-m: 0 12px 48px rgba(18,69,234,.18);
  --shadow-l: 0 32px 80px rgba(10,15,30,.22);
  --font-head: 'Cairo', sans-serif;
  --font-body: 'Tajawal', sans-serif;
  --ease-out: cubic-bezier(0.16,1,0.3,1);
}

/* ─── RESET ──────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: var(--font-body);
  background: var(--white);
  color: var(--ink);
  line-height: 1.7;
  overflow-x: hidden;
  direction: rtl;
  text-align: right;
}
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }

/* ─── SCROLL REVEAL ──────────────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity .7s var(--ease-out), transform .7s var(--ease-out);
}
.reveal.is-visible { opacity: 1; transform: none; }
.reveal-left  { transform: translateX(50px); }
.reveal-right { transform: translateX(-50px); }
.reveal-left.is-visible, .reveal-right.is-visible { transform: none; }

/* ─── NAV ────────────────────────────────────────────────── */
nav {
  position: fixed;
  top: 0; right: 0; left: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 5%;
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(18,69,234,.08);
  transition: box-shadow .3s;
  direction: rtl;
}
nav.scrolled { box-shadow: 0 4px 24px rgba(10,15,30,.1); }

.nav-logo {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 1.4rem;
  letter-spacing: 0;
  color: var(--ink);
  display: flex;
  align-items: center;
  gap: 8px;
  flex-direction: row-reverse;
}
.nav-logo span { color: var(--blue-1); }
.logo-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--teal);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%,100% { transform: scale(1); opacity: 1; }
  50%      { transform: scale(1.4); opacity: .7; }
}

.nav-cta {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--wa);
  color: #fff;
  font-family: var(--font-body);
  font-weight: 700;
  font-size: .9rem;
  padding: 10px 20px;
  border-radius: 100px;
  transition: transform .2s, box-shadow .2s;
  box-shadow: 0 4px 16px rgba(37,211,102,.35);
  flex-direction: row-reverse;
}
.nav-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,211,102,.45); }
.nav-cta svg { width: 16px; height: 16px; }

/* ─── HERO ───────────────────────────────────────────────── */
#hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 120px 5% 80px;
  overflow: hidden;
  background: var(--ink);
}
.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 30% 40%, rgba(18,69,234,.35) 0%, transparent 70%),
    radial-gradient(ellipse 50% 40% at 80% 80%, rgba(0,212,200,.2) 0%, transparent 60%),
    var(--ink);
}
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at center, black 20%, transparent 100%);
}
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  opacity: .5;
  pointer-events: none;
}
.orb-1 { width: 400px; height: 400px; background: var(--blue-1); top: -100px; left: 5%; animation: drift1 8s ease-in-out infinite; }
.orb-2 { width: 250px; height: 250px; background: var(--teal); bottom: 5%; right: 10%; animation: drift2 10s ease-in-out infinite; }
@keyframes drift1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(30px,20px)} }
@keyframes drift2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-20px,-30px)} }

.hero-inner {
  position: relative;
  max-width: 740px;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.18);
  backdrop-filter: blur(8px);
  color: #fff;
  font-size: .85rem;
  font-weight: 600;
  letter-spacing: 0;
  padding: 7px 16px 7px 10px;
  border-radius: 100px;
  margin-bottom: 28px;
  flex-direction: row-reverse;
}
.hero-badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--teal);
  animation: pulse 2s infinite;
}
.hero-h1 {
  font-family: var(--font-head);
  font-size: clamp(2.4rem, 5.5vw, 4.2rem);
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: 0;
  color: #fff;
  margin-bottom: 24px;
}
.hero-h1 .accent {
  background: linear-gradient(135deg, var(--teal), var(--blue-2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,.65);
  max-width: 520px;
  margin-bottom: 44px;
  font-weight: 300;
}
.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
}
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, var(--wa), #1ebe57);
  color: #fff;
  font-family: var(--font-body);
  font-weight: 700;
  font-size: 1.05rem;
  padding: 16px 32px;
  border-radius: 100px;
  box-shadow: 0 8px 32px rgba(37,211,102,.45);
  transition: transform .25s var(--ease-out), box-shadow .25s;
  cursor: pointer;
  border: none;
  flex-direction: row-reverse;
}
.btn-primary:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 14px 40px rgba(37,211,102,.55); }
.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,.1);
  color: rgba(255,255,255,.85);
  font-weight: 600;
  font-size: .95rem;
  padding: 15px 28px;
  border-radius: 100px;
  border: 1px solid rgba(255,255,255,.2);
  backdrop-filter: blur(8px);
  transition: background .2s, border-color .2s;
}
.btn-secondary:hover { background: rgba(255,255,255,.18); border-color: rgba(255,255,255,.4); }

.hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 32px;
  margin-top: 60px;
  padding-top: 40px;
  border-top: 1px solid rgba(255,255,255,.1);
}
.stat-item { color: #fff; }
.stat-num {
  font-family: var(--font-head);
  font-size: 2rem;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 4px;
  direction: ltr;
  text-align: right;
}
.stat-num span { color: var(--teal); }
.stat-label { font-size: .85rem; color: rgba(255,255,255,.5); font-weight: 400; }

/* ─── SECTION WRAPPER ────────────────────────────────────── */
section { padding: 100px 5%; }
.section-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: .8rem;
  font-weight: 700;
  letter-spacing: 0;
  color: var(--blue-1);
  margin-bottom: 16px;
  flex-direction: row-reverse;
}
.section-tag::after {
  content: '';
  display: block;
  width: 20px; height: 2px;
  background: var(--blue-1);
  border-radius: 2px;
}
.section-title {
  font-family: var(--font-head);
  font-size: clamp(1.9rem, 4vw, 3rem);
  font-weight: 900;
  line-height: 1.25;
  color: var(--ink);
  margin-bottom: 16px;
}
.section-sub {
  font-size: 1rem;
  color: var(--silver);
  max-width: 540px;
  font-weight: 300;
}

/* ─── SERVICES ───────────────────────────────────────────── */
#services { background: var(--ghost); }
.services-header { margin-bottom: 56px; }
.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
}
.service-card {
  background: var(--white);
  border-radius: var(--radius-m);
  padding: 32px 28px;
  border: 1px solid rgba(18,69,234,.07);
  box-shadow: 0 2px 16px rgba(10,15,30,.05);
  transition: transform .35s var(--ease-out), box-shadow .35s;
  cursor: default;
  position: relative;
  overflow: hidden;
}
.service-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(18,69,234,.04), rgba(0,212,200,.04));
  opacity: 0;
  transition: opacity .35s;
}
.service-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-m); }
.service-card:hover::before { opacity: 1; }
.service-icon {
  width: 60px; height: 60px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.7rem;
  margin-bottom: 20px;
  background: linear-gradient(135deg, #eef2ff, #e0f7fa);
}
.service-name {
  font-family: var(--font-head);
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--ink);
  margin-bottom: 10px;
}
.service-desc {
  font-size: .92rem;
  color: var(--silver);
  line-height: 1.75;
}
.platforms {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 16px;
}
.chip {
  font-size: .78rem;
  font-weight: 600;
  background: var(--ghost);
  color: var(--ink-2);
  padding: 5px 12px;
  border-radius: 100px;
  border: 1px solid rgba(18,69,234,.1);
  font-family: var(--font-body);
  direction: ltr;
}

/* ─── TRUST ──────────────────────────────────────────────── */
#trust { background: var(--ink); overflow: hidden; position: relative; }
.trust-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 20% 50%, rgba(18,69,234,.25), transparent 70%);
  pointer-events: none;
}
.trust-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 56px 80px;
  align-items: center;
}
.trust-copy .section-tag { color: var(--teal); }
.trust-copy .section-tag::after { background: var(--teal); }
.trust-copy .section-title { color: #fff; }
.trust-copy .section-sub { color: rgba(255,255,255,.5); }
.trust-items {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 32px;
}
.trust-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 18px 20px;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--radius-s);
  transition: background .3s, border-color .3s, transform .3s;
  flex-direction: row-reverse;
  text-align: right;
}
.trust-item:hover { background: rgba(255,255,255,.09); border-color: rgba(0,212,200,.3); transform: translateX(-6px); }
.trust-icon {
  flex-shrink: 0;
  width: 44px; height: 44px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--blue-1), var(--teal));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
}
.trust-text strong {
  display: block;
  font-family: var(--font-head);
  color: #fff;
  font-weight: 800;
  font-size: 1rem;
  margin-bottom: 4px;
}
.trust-text p { font-size: .88rem; color: rgba(255,255,255,.5); }

/* Card mock */
.trust-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.trust-card-mock {
  background: linear-gradient(135deg, var(--blue-1), var(--blue-2));
  border-radius: var(--radius-l);
  width: 320px;
  height: 420px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 36px;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-l);
}
.mock-shine {
  position: absolute;
  top: -60px; left: -60px;
  width: 240px; height: 240px;
  background: radial-gradient(circle, rgba(255,255,255,.25), transparent 70%);
  border-radius: 50%;
}
.mock-chip { width: 44px; height: 32px; background: var(--gold); border-radius: 6px; margin-bottom: 30px; position: relative; z-index: 1; }
.mock-num { font-family: 'Cairo', sans-serif; color: rgba(255,255,255,.7); font-size: .85rem; letter-spacing: 2px; position: relative; z-index: 1; margin-bottom: 8px; direction: ltr; text-align: left; }
.mock-name { font-family: var(--font-head); color: #fff; font-size: 1.1rem; font-weight: 800; position: relative; z-index: 1; }
.mock-badge {
  position: absolute;
  top: 28px; left: 28px;
  background: rgba(255,255,255,.15);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.25);
  border-radius: 100px;
  padding: 6px 14px;
  color: #fff;
  font-size: .78rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6px;
}
.mock-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--teal); animation: pulse 2s infinite; }
.floating-pill {
  position: absolute;
  background: var(--white);
  border-radius: 100px;
  padding: 10px 18px;
  box-shadow: var(--shadow-s);
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: .82rem;
  font-weight: 700;
  color: var(--ink);
  white-space: nowrap;
  flex-direction: row-reverse;
}
.pill-1 { top: 40px; right: -40px; animation: floatY 4s ease-in-out infinite; }
.pill-2 { bottom: 60px; left: -50px; animation: floatY 5s ease-in-out infinite .8s; }
@keyframes floatY { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
.pill-icon { font-size: 1rem; }

/* ─── LOCAL TRUST ────────────────────────────────────────── */
#local {
  background: linear-gradient(135deg, #f0f3fa 0%, #e8f0fe 100%);
  text-align: center;
}
.local-inner { max-width: 700px; margin: 0 auto; }
.store-graphic {
  width: 100px; height: 100px;
  border-radius: 28px;
  background: linear-gradient(135deg, var(--blue-1), var(--teal));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.8rem;
  margin: 0 auto 32px;
  box-shadow: var(--shadow-s);
}
.local-title {
  font-family: var(--font-head);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 900;
  margin-bottom: 16px;
  color: var(--ink);
  line-height: 1.3;
}
.local-sub {
  font-size: 1rem;
  color: var(--silver);
  max-width: 500px;
  margin: 0 auto;
  line-height: 1.8;
}

/* ─── CONTACT ────────────────────────────────────────────── */
#contact { background: var(--white); }
.contact-wrap {
  max-width: 980px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.contact-copy .section-title { margin-bottom: 20px; }
.contact-copy p { color: var(--silver); margin-bottom: 32px; font-size: .95rem; }
.contact-info-item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
  font-size: .95rem;
  color: var(--ink-2);
  flex-direction: row-reverse;
  text-align: right;
}
.info-icon {
  width: 38px; height: 38px;
  border-radius: 9px;
  background: var(--ghost);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  flex-shrink: 0;
}
.contact-card {
  background: linear-gradient(160deg, #0a0f1e, #1a2035);
  border-radius: var(--radius-l);
  padding: 44px 36px;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-l);
}
.contact-card::before {
  content: '';
  position: absolute;
  top: -60px; left: 50%;
  transform: translateX(-50%);
  width: 280px; height: 280px;
  background: radial-gradient(circle, rgba(18,69,234,.4), transparent 70%);
  pointer-events: none;
}
.wa-logo-big {
  width: 80px; height: 80px;
  border-radius: 24px;
  background: var(--wa);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  box-shadow: 0 12px 32px rgba(37,211,102,.45);
  position: relative;
  z-index: 1;
  animation: waFloat 3s ease-in-out infinite;
}
@keyframes waFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.wa-logo-big svg { width: 44px; height: 44px; fill: #fff; }
.contact-card h3 {
  font-family: var(--font-head);
  font-size: 1.5rem;
  font-weight: 900;
  color: #fff;
  margin-bottom: 10px;
  position: relative;
  z-index: 1;
}
.contact-card p { color: rgba(255,255,255,.5); font-size: .9rem; margin-bottom: 28px; position: relative; z-index: 1; }
.btn-wa-big {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  background: linear-gradient(135deg, var(--wa), #1ebe57);
  color: #fff;
  font-weight: 800;
  font-size: 1.05rem;
  padding: 18px 32px;
  border-radius: 100px;
  box-shadow: 0 8px 28px rgba(37,211,102,.4);
  transition: transform .25s var(--ease-out), box-shadow .25s;
  position: relative;
  z-index: 1;
  flex-direction: row-reverse;
}
.btn-wa-big:hover { transform: scale(1.03) translateY(-2px); box-shadow: 0 14px 36px rgba(37,211,102,.55); }
.phone-display {
  margin-top: 20px;
  font-size: .88rem;
  color: rgba(255,255,255,.4);
  position: relative;
  z-index: 1;
}
.phone-display a { color: rgba(255,255,255,.7); font-weight: 600; direction: ltr; display: inline-block; }

/* ─── FINAL CTA ──────────────────────────────────────────── */
#final-cta {
  background: var(--ink);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.final-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 50% 100%, rgba(18,69,234,.3), transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 20%, rgba(0,212,200,.15), transparent 60%);
}
.final-inner {
  position: relative;
  max-width: 700px;
  margin: 0 auto;
}
.final-inner .section-tag { color: var(--teal); justify-content: center; }
.final-inner .section-tag::after { background: var(--teal); }
.final-title {
  font-family: var(--font-head);
  font-size: clamp(2rem, 4.5vw, 3.4rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.25;
  margin-bottom: 20px;
}
.final-title .hl {
  background: linear-gradient(135deg, var(--teal), var(--blue-2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.final-sub {
  color: rgba(255,255,255,.5);
  font-size: 1rem;
  margin-bottom: 44px;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.8;
}

/* ─── FOOTER ─────────────────────────────────────────────── */
footer {
  background: #07090f;
  padding: 36px 5%;
  text-align: center;
  font-size: .85rem;
  color: rgba(255,255,255,.3);
  font-family: var(--font-body);
}
footer strong { color: rgba(255,255,255,.6); font-family: var(--font-head); }

/* ─── STICKY WA ──────────────────────────────────────────── */
.sticky-wa {
  position: fixed;
  bottom: 28px;
  left: 28px;
  z-index: 200;
  width: 60px; height: 60px;
  border-radius: 50%;
  background: var(--wa);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 28px rgba(37,211,102,.55);
  transition: transform .25s var(--ease-out), box-shadow .25s;
  animation: waFloat 3s ease-in-out infinite;
}
.sticky-wa:hover { transform: scale(1.12); box-shadow: 0 10px 36px rgba(37,211,102,.7); }
